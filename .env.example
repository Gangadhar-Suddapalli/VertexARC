# Copy this file to .env (for local development) and fill in your key.

# ---------------------------------------------------------------------------
# Chat / summary model provider
# ---------------------------------------------------------------------------
# "groq" (free tier, default) or "openai".
LLM_PROVIDER=groq

# Groq key (used when LLM_PROVIDER=groq). Create one (free) at:
#   https://console.groq.com/keys
GROQ_API_KEY=gsk_your-groq-api-key-here

# OpenAI key (used only when LLM_PROVIDER=openai). https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-your-openai-api-key-here

# Optional chat model override. Defaults: Groq -> llama-3.3-70b-versatile,
# OpenAI -> gpt-4o-mini. Other good free Groq options:
#   llama-3.1-8b-instant (faster), openai/gpt-oss-20b, openai/gpt-oss-120b
# CHAT_MODEL=llama-3.3-70b-versatile

# ---------------------------------------------------------------------------
# Embeddings (independent of the chat provider)
# ---------------------------------------------------------------------------
# "local" (open-source, free, no API cost) or "openai".
EMBED_BACKEND=local

# Local (open-source) embedding model, used when EMBED_BACKEND=local.
# Good options: BAAI/bge-base-en-v1.5 (default), BAAI/bge-small-en-v1.5 (faster),
# intfloat/e5-base-v2, mixedbread-ai/mxbai-embed-large-v1 (best quality, needs GPU).
LOCAL_EMBED_MODEL=BAAI/bge-base-en-v1.5

# Used only when EMBED_BACKEND=openai (requires OPENAI_API_KEY).
OPENAI_EMBED_MODEL=text-embedding-3-small
